# Copy to .env (local) or set as User environment variables (Windows).
# OPENKB CLI is NOT on PATH by default — use scripts/openkb.ps1 or uv run (see skill).

# Required: OpenKB install root (absolute path)
OPENKB_ROOT=E:/AProject/TianX/Personal/OpenKB

# Required for agents: identity for locks and audit trail
OPENKB_AGENT_ID=your-agent-name

# Optional: force project slug (overrides .openkb-link and repo_path match)
# OPENKB_PROJECT=openkb

# Recommended (Windows): keep uv/npm caches off C:
UV_CACHE_DIR=E:/uv-cache

# E2E / CI: Playwright browser cache (optional)
# PLAYWRIGHT_BROWSERS_PATH=E:/playwright-browsers

# CLI → running serve: WebSocket notify (default 127.0.0.1:8788)
# OPENKB_SERVE_PORT=8788
# OPENKB_SERVE_HOST=127.0.0.1
